---
import ModuleLayout from '../../layouts/ModuleLayout.astro';
import SectionCard from '../../components/SectionCard.astro';
import Objectives from '../../components/sections/Objectives.astro';
import Overview from '../../components/sections/Overview.astro';
import Vocabulary from '../../components/sections/Vocabulary.astro';
import Grammar from '../../components/sections/Grammar.astro';
import Practice from '../../components/sections/Practice.astro';
import Exercise from '../../components/sections/Exercise.astro';
import Summary from '../../components/sections/Summary.astro';
import Reflection from '../../components/sections/Reflection.astro';

const moduleData = {
  objectives: {
    objectives: [
      "C1 Identify the structure and criteria of OET Speaking",
      "C2 Explain patient-friendly vocabulary, based on the context",
      "C2 Explain grammar, and empathy strategies",
      "C3 Apply appropriate language in structured speaking tasks using chatbot",
      "C4 Analyze patient needs and emotional cues and do a roleplay with the chatbot.",
      "C5 Evaluate speaking performance using OET criteria and AI feedback",
      "C6 Produce a clear, empathetic, and coherent OET role-play",
    ],
  },

  overview: {
    overview: {
      testDescription: "The OET Speaking test has a short warm-up (not scored) and two role-plays. In each role-play, you act as a healthcare professional, and the examiner is the patient or carer. Before speaking, you have 3 minutes to prepare. During this time, read the situation, understand your role, check the patient's problem, and think of simple phrases to use. During the role-play, start with a polite greeting, ask simple questions, and show empathy. Give clear explanations and advice using easy and polite language. Do not speak too directly. Also, give the patient time to respond and keep the conversation natural. To improve, practice role-plays, learn useful phrases, and remember that effective communication is more important than perfect grammar.",
      videoUrl: "https://youtu.be/akVuiN3m49c?si=6ef3Kwx1Sxo45fEX",
      quizUrl: "https://app.edcafe.ai/youtube-quiz/696deafbf109ed45c70fe1f2",
      quizImage: "/images/image6.png",
      frameworkMnemonic: "OPEN → ASK → EXPLAIN → REASSURE → ADVISE → CLOSE",
      frameworkDescription: 'The "OET Speaking Blueprint: Beginner\'s Clinical Dialogue Guide" provides a standardized, six-step framework designed to facilitate clear and professional communication between healthcare providers and patients. The framework prioritizes polite engagement, systematic information gathering, and structured delivery of medical information. Key takeaways include the differentiation of dialogue based on clinical setting (clinic vs. hospital) and a specific pedagogical model for explaining medical conditions: linking cause, symptoms, treatment, and preventative advice in a logical sequence.',
      frameworkPdf: "https://drive.google.com/file/d/1qhteybDPvAL2uzQiWKZ0DDBKIKocJiPL/view",
    },
    criteria: {
      languageSkills: "The OET speaking subtest is assessed based on two main areas: <strong>language skills</strong> and <strong>clinical communication</strong>. <em>Language skills</em> focus on how clearly and smoothly you speak, including clarity (easy to understand), fluency (natural speed), appropriateness (using the right tone), and accuracy (correct grammar and vocabulary).",
      clinicalCommunication: "<em>Clinical communication</em> measures how well you interact with the patient, such as building a good relationship, understanding the patient's feelings, organizing the conversation clearly, and giving and gathering information effectively. To get a good score, you need to speak clearly, use simple and correct language, show empathy, and guide the patient step by step during the conversation.",
      scoringPdf: "https://drive.google.com/file/d/1-lLyHjdWEBkx7N-IxAQv89WHfoqEBf1J/view",
      criteriaImage: "/images/image1.png",
    },
  },

vocabulary: {
    quizUrl: "https://app.edcafe.ai/quizzes/69899ca63159d0c298cf730f",
    quizImage: "/images/image5.png",
    vocabularyItems: [
      { no: 1, word: "pregnant", meaning: "having a baby in the body", example: "You may be pregnant, but we need to confirm it first." },
      { no: 2, word: "pregnancy test", meaning: "a test to check pregnancy", example: "Have you taken a pregnancy test yet?" },
      { no: 3, word: "positive", meaning: "showing yes/result is true", example: "A positive result usually means you are pregnant." },
      { no: 4, word: "worried", meaning: "feeling nervous or concerned", example: "I understand that you are feeling worried right now." },
      { no: 5, word: "shocked", meaning: "very surprised", example: "It's okay to feel shocked after hearing this result." },
      { no: 6, word: "advice", meaning: "helpful suggestion", example: "I will give you some advice on what to do next." },
      { no: 7, word: "confidential", meaning: "private, not shared with others", example: "Everything we talk about here is confidential." },
      { no: 8, word: "decision", meaning: "a choice you make", example: "This is your decision, and we will respect it." },
      { no: 9, word: "support", meaning: "help from someone", example: "You don't have to go through this alone, we can support you." },
      { no: 10, word: "options", meaning: "different choices", example: "Let me explain the options available to you." },
      { no: 11, word: "specialist", meaning: "doctor with special knowledge", example: "I can refer you to a specialist for further care." },
      { no: 12, word: "trust", meaning: "to believe someone is safe or honest", example: "You can trust me to help you through this situation." },
      { no: 13, word: "parents", meaning: "mother and father", example: "Have you talked to your parents about this?" },
      { no: 14, word: "unexpected", meaning: "not planned or not expected", example: "I understand this may be an unexpected situation for you." },
      { no: 15, word: "discuss", meaning: "to talk about something", example: "We can discuss your concerns and any questions you have." },
    ],
  },

  grammar: {
    grammarDescription: "In OET Speaking, you should use simple and clear grammar to communicate with patients. You do not need long or difficult sentences. Instead, use an easy pattern like <strong>Subject + Modal + Verb + Object</strong> (e.g., <em>I need to check your leg first</em>) to make your speech polite and clear. Use modal verbs like <em>can</em>, <em>should</em>, <em>need to</em>, and <em>cannot</em> to sound more polite, especially when giving advice or refusing requests. You can also use simple if-sentences (first conditional) to explain risks, such as what may happen if a patient takes certain medicine. The key idea is to speak in short, simple sentences, use everyday words, and avoid complicated grammar so the patient can easily understand you.",
    grammarPdf: "https://drive.google.com/file/d/1n2dSd8KL1iB_rFrGbj-G_qPekImbSyTg/view",
    videoUrl: "https://youtu.be/WURhySarfuA",
  },

  practice: {
    cueCardsDoctor: [
      { image: "/images/image3.png", alt: "Doctor Cue Card", caption: "Cue Card (Doctor Role)" },
    ],
    cueCardsPatient: [
      { image: "/images/image2.png", alt: "Patient Cue Card", caption: "Cue Card (Patient Role)" },
    ],
    chatbot: {
      link: "https://app.edcafe.ai/chatbots/6980bd93bef19e699efac1ad",
      qrImage: "/images/image4.png",
    },
    stepsDoctor: [
      "Open the chatbot link and enter your full name.",
      "Take a screenshot of the role-play cue card (Doctor or Patient) and upload it to the chatbot.",
      'Type the prompt:<br/><em>"Read the attached cue card and guide me to practice."</em><br/>In this context a chatbot functions as structured practice tool and automatic feedback.',
      "Follow the chatbot's guidance step by step: <ul><li>Speak one idea at a time</li><li>Use short, clear sentences</li><li>Pronounce words clearly</li><li>Repeat the practice until all tasks on the cue card are completed.</li></ul>",
      "Read the summary feedback provided by the chatbot.",
      "Answer the reflection questions about your speaking experience.",
      "Copy all your answers into one page to form a complete dialogue (doctor–patient).",
    ],
    stepsPatient: [
      'Take a screenshot of the role-play cue card (Patient) and upload it to the chatbot.',
      'Type the prompt: "Read the attached cue card and guide me to practice."',
      "Follow the chatbot's guidance step by step: <ul><li>Speak one idea at a time</li><li>Use short, clear sentences</li><li>Pronounce words clearly</li><li>Repeat the practice until all tasks on the cue card are completed.</li></ul>",
      "Read the summary feedback provided by the chatbot.",
      "Answer the reflection questions about your speaking experience.",
    ],
    mergePrompt: "Merge the conversation between a doctor and a patient in the attached file so it becomes a complete dialogue between a patient and a doctor",
    exampleLink: "https://docs.google.com/document/d/1UTEDSJ3nujgSJsKYZ523A8mbQCI9XzZp_495p3V0H6I/edit?usp=sharing",
    stepsPartner: [
      "Open your pdf files you uploaded before to help you respond the chatbot",
      "Upload two cue cards: doctor and patient",
      'To start, Use this prompt:<br/><em>"Read the attached cue cards and be my conversational partner. You take a role as a patient. I will be a doctor. Make sure your questions are in line with the patient\'s task in the cue card. Can we start?"</em><br/>In this context a chatbot functions as conversational partner.',
    ],
    partnerExampleLink: "https://docs.google.com/document/d/1Z53yrMLP0JvIzKIDf_AVhD5zbry4NKJkC3b-b9LkGhI/edit?usp=sharing",
  },

  exercise: {
    introduction: "After you finish the pre-class and chatbot practice, you are ready to practice in class. At this stage, you will apply what you have learned in real speaking activities. You will practice, get feedback, and improve step by step. These activities help you speak more clearly and communicate better in a clinical situation.",
    executingRoleplay: "In this stage, you do a role-play with a partner. One of you is the doctor, and the other is the patient. You use OET-style situations. You try to start, continue, and finish the conversation. You should speak clearly, use simple and appropriate language, and show care to the patient.",
    feedbackFromLecturer: "After the role-play, you get feedback from the lecturer. The feedback looks at your fluency, pronunciation, vocabulary, and how you communicate with the patient. You use this feedback to understand what you did well and what you need to improve.",
    scoringTemplateUrl: "https://docs.google.com/spreadsheets/d/1BAXEw1zzsxVuAgN9jWypBL5yzOLW6Zke/edit?usp=sharing&ouid=117030556830380000197&rtpof=true&sd=true",
    criteria: [
      { section: "<strong>A. Linguistic Competence</strong>", criterion: "<strong>Intelligibility</strong>", descriptor: "Pronunciation clarity, stress, and intonation<br/>Is the speech clear and easy to understand?" },
      { section: "", criterion: "<strong>Fluency</strong>", descriptor: "Speech flow, pace, and hesitation<br/>Is the speech smooth or full of hesitation?" },
      { section: "", criterion: "<strong>Appropriateness of Language</strong>", descriptor: "Use of patient-friendly and professional language<br/>Is the language polite, professional, patient-friendly?" },
      { section: "", criterion: "<strong>Grammar & Expression</strong>", descriptor: "Control and range of grammatical structures<br/>Are sentences accurate and varied?" },
      { section: "", criterion: "<strong>Vocabulary Range</strong>", descriptor: "Precision and breadth of vocabulary<br/>Is vocabulary precise and appropriate?" },
      { section: "<strong>Linguistic Subtotal</strong>", criterion: "—", descriptor: "—" },
      { section: "<strong>B. Clinical Communication Competence</strong>", criterion: "<strong>Relationship Building</strong>", descriptor: "Empathy, rapport, and respect<br/>Does the speaker show empathy and rapport?" },
      { section: "", criterion: "<strong>Understanding Patient Perspective</strong>", descriptor: "Acknowledgement of patient concerns and feelings<br/>Are patient concerns acknowledged?" },
      { section: "", criterion: "<strong>Providing Structure</strong>", descriptor: "Organization and clear signposting<br/>Is the conversation organized logically?" },
      { section: "", criterion: "<strong>Information Gathering</strong>", descriptor: "Effective questioning and active listening<br/>Are relevant questions asked?" },
      { section: "", criterion: "<strong>Information Giving</strong>", descriptor: "Clarity and usefulness of explanations<br/>Is information clear and understandable?" },
      { section: "<strong>Clinical Subtotal</strong>", criterion: "—", descriptor: "—" },
    ],
  },

  summary: {
    content: "This chapter strengthened OET Speaking skills by integrating key medical vocabulary, patient-friendly grammar, and empathetic communication strategies. Through a flipped classroom supported by AI tools, students progressed from recognizing language forms to creating complete, confident, and compassionate OET role-plays aligned with Band D–C expectations.",
  },

  reflection: {
    formUrl: "https://forms.gle/L7MMW1HAfDqb4rtKA",
    sections: [
      {
        title: "Language Reflection",
        questions: [
          "Which vocabulary felt most useful today?",
          "Which grammar structure helped me sound more professional?",
          "Which part of the learning process do you find interesting? And why?",
        ],
      },
      {
        title: "Personal Reflection",
        questions: [
          "How confident did I feel speaking today?",
          "One improvement I will focus on next time is?",
          "How will I improve it?",
        ],
      },
      {
        title: "AI Chatbot Reflection",
        questions: [
          "Does the chatbot help me improve?",
          "How does the chatbot improve it?",
        ],
      },
    ],
  },
};

const sections = [
  { id: 'objectives', title: 'Learning Objectives', type: 'objectives' },
  { id: 'overview', title: 'Overview', type: 'overview' },
  { id: 'vocabulary', title: 'Vocabulary', type: 'vocabulary' },
  { id: 'grammar', title: 'Grammar', type: 'grammar' },
  { id: 'practice', title: 'Practice', type: 'practice' },
  { id: 'exercise', title: 'Role-Play', type: 'exercise' },
  { id: 'summary', title: 'Summary', type: 'summary' },
  { id: 'reflection', title: 'Reflection', type: 'reflection' },
];

const preClassSections = ['objectives', 'overview', 'vocabulary', 'grammar', 'practice'];
const inClassSections = ['exercise', 'summary', 'reflection'];
---

<ModuleLayout
  moduleNumber={2}
  title="Speaking 1"
  description="Learn the foundational skills for OET Speaking sub-test including structure, vocabulary, grammar, and practice with AI chatbot."
>
  <div class="section-group">
    <h2 class="group-label">Pre-Class Activities</h2>
    {sections.filter(s => preClassSections.includes(s.id)).map((section) => (
      <SectionCard id={section.id} title={section.title}>
        {section.type === 'objectives' && <Objectives data={moduleData.objectives} />}
        {section.type === 'overview' && <Overview data={moduleData.overview} />}
        {section.type === 'vocabulary' && <Vocabulary data={moduleData.vocabulary} />}
        {section.type === 'grammar' && <Grammar data={moduleData.grammar} />}
        {section.type === 'practice' && <Practice data={moduleData.practice} />}
      </SectionCard>
    ))}
  </div>

  <div class="section-group">
    <h2 class="group-label">In-Class Activities</h2>
    {sections.filter(s => inClassSections.includes(s.id)).map((section) => (
      <SectionCard id={section.id} title={section.title}>
        {section.type === 'exercise' && <Exercise data={moduleData.exercise} />}
        {section.type === 'summary' && <Summary data={moduleData.summary} />}
        {section.type === 'reflection' && <Reflection data={moduleData.reflection} />}
      </SectionCard>
    ))}
  </div>
</ModuleLayout>

<style>
  .section-group {
    margin-bottom: var(--space-10);
  }

  .group-label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 2px solid var(--color-primary);
  }
</style>