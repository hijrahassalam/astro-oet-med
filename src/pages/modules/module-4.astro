---
import ModuleLayout from '../../layouts/ModuleLayout.astro';
import SectionCard from '../../components/SectionCard.astro';
---

<ModuleLayout
  moduleNumber={4}
  title="Speaking 3"
  description="Develop professional fluency in complex clinical dialogues and difficult conversations."
>
  <SectionCard id="overview" title="Overview">
    <div class="coming-soon-box">
      <p>This module is currently under development.</p>
      <p>It will be available soon. Please check back later.</p>
    </div>
  </SectionCard>

  <SectionCard id="vocabulary" title="Vocabulary">
    <p>Content coming soon.</p>
  </SectionCard>

  <SectionCard id="grammar" title="Grammar">
    <p>Content coming soon.</p>
  </SectionCard>

  <SectionCard id="practice" title="Practice">
    <p>Content coming soon.</p>
  </SectionCard>

  <SectionCard id="exercise" title="Exercise">
    <p>Content coming soon.</p>
  </SectionCard>

  <SectionCard id="summary" title="Summary">
    <p>Content coming soon.</p>
  </SectionCard>

  <SectionCard id="reflection" title="Reflection">
    <p>Content coming soon.</p>
  </SectionCard>
</ModuleLayout>

<style>
  .coming-soon-box {
    background: linear-gradient(135deg, var(--color-warning-light), var(--color-surface));
    border: 1px solid var(--color-warning);
    border-radius: var(--card-radius);
    padding: var(--space-6);
    text-align: center;
  }

  .coming-soon-box p {
    margin-bottom: var(--space-2);
    color: var(--color-text-secondary);
  }

  .coming-soon-box p:last-child {
    margin-bottom: 0;
    font-weight: 600;
    color: var(--color-text);
  }
</style>