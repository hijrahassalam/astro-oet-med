---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  description?: string;
  moduleNumber: number;
}

const { title, description, moduleNumber } = Astro.props;

const sections = [
  { id: 'overview', label: 'Overview' },
  { id: 'vocabulary', label: 'Vocabulary' },
  { id: 'grammar', label: 'Grammar' },
  { id: 'practice', label: 'Practice' },
  { id: 'exercise', label: 'Exercise' },
  { id: 'summary', label: 'Summary' },
  { id: 'reflection', label: 'Reflection' },
];
---

<BaseLayout title={`${title} — Module ${moduleNumber}`} description={description}>
  <div class="module-header">
    <div class="container">
      <a href="/" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M10 12L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        All Modules
      </a>
      <span class="module-badge">Module {moduleNumber}</span>
      <h1 class="module-title">{title}</h1>
      {description && <p class="module-description">{description}</p>}
    </div>
  </div>

  <div class="module-layout container">
    <Sidebar sections={sections} />
    <div class="module-content">
      <slot />
    </div>
  </div>
</BaseLayout>

<style>
  .module-header {
    background: linear-gradient(180deg, var(--color-primary-50), var(--color-bg));
    padding: var(--space-8) 0 var(--space-10);
    border-bottom: 1px solid var(--color-border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    transition: color var(--transition-fast);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .module-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: white;
    font-size: var(--text-xs);
    font-weight: 600;
    border-radius: 100px;
    margin-bottom: var(--space-3);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .module-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-3);
  }

  .module-description {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 640px;
    margin-bottom: 0;
    line-height: var(--leading-relaxed);
  }

  .module-layout {
    display: grid;
    grid-template-columns: var(--sidebar-width) 1fr;
    gap: var(--space-10);
    padding-top: var(--space-8);
    padding-bottom: var(--space-16);
  }

  .module-content {
    min-width: 0;
  }

  @media (max-width: 900px) {
    .module-layout {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .module-title {
      font-size: var(--text-3xl);
    }
  }
</style>

<script>
  const slug = window.location.pathname.split('/').filter(Boolean).pop();
  if (slug) {
    localStorage.setItem(`module-${slug}-state`, 'progress');
  }
</script>
