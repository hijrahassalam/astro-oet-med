---
interface Props {
  data: {
    title: string;
    description: string;
  };
}

const { data } = Astro.props;
---

<div class="assessment">
  <p class="assessment-ready">
    Now, you are ready to create a role-play video based on the same case. Your role-play should take
    into account the feedback from your lecturer so that it improves on your previous performance.
    Your video submission will be assessed by your lecturer.
  </p>
  <p class="assessment-description">{data.description}</p>
  <div class="score-scale">
    <div class="scale-item scale-high">
      <span class="score">4 – 6</span>
      <span class="label">Adequate → Good → Excellent</span>
      <span class="note">You can continue to the next level.</span>
    </div>
    <div class="scale-item scale-low">
      <span class="score">1 – 3</span>
      <span class="label">Very Poor → Poor → Limited</span>
      <span class="note">You need to do remedial role-play to practice and improve before continuing.</span>
    </div>
  </div>
</div>

<style>
  .assessment {
    font-family: var(--font-body, sans-serif);
  }

  .assessment-description {
    font-size: var(--text-base, 0.9375rem);
    line-height: 1.7;
    color: var(--color-text, #374151);
    margin-bottom: var(--space-6, 1.5rem);
  }

  .score-scale {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4, 1rem);
  }

  .scale-item {
    padding: var(--space-4, 1rem);
    border-radius: 0.5rem;
    border: 1px solid;
  }

  .scale-high {
    background-color: #f0fdf4;
    border-color: #bbf7d0;
  }

  .scale-low {
    background-color: #fef2f2;
    border-color: #fecaca;
  }

  .score {
    display: block;
    font-size: var(--text-xl, 1.25rem);
    font-weight: 700;
    color: var(--color-text, #374151);
    margin-bottom: 0.25rem;
  }

  .label {
    display: block;
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    color: var(--color-text, #374151);
    margin-bottom: 0.5rem;
  }

  .note {
    display: block;
    font-size: var(--text-sm, 0.875rem);
    color: var(--color-text-muted, #6b7280);
    line-height: 1.5;
  }

  .assessment-ready {
    font-size: var(--text-base, 0.9375rem);
    line-height: 1.7;
    color: var(--color-text, #374151);
    margin-top: var(--space-6, 1.5rem);
    padding: var(--space-4, 1rem);
    background: var(--color-primary-50, #eff6ff);
    border-left: 3px solid var(--color-primary, #2563eb);
    border-radius: 0 0.5rem 0.5rem 0;
  }

  @media (max-width: 640px) {
    .score-scale {
      grid-template-columns: 1fr;
    }
  }
</style>
