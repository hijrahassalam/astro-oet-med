---
import CtaButton from '../CtaButton.astro';

interface Props {
  data: {
    headerImage: string;
    grammarDescription: string;
    grammarPdf: string;
    videoUrl: string;
  };
}

const { data } = Astro.props;
---

<div class="grammar-content">
  <h3>4. Grammar for OET Speaking</h3>
  <p set:html={data.grammarDescription}></p>

  <div class="grammar-note">
    <p><strong>📌 Instruction for Students:</strong></p>
    <div class="cta-stack">
      <CtaButton href={data.grammarPdf} variant="secondary" size="md">
        📄 Download Grammar PDF
      </CtaButton>
      <CtaButton href={data.videoUrl} variant="primary" size="md">
        📺 Watch Grammar Video
      </CtaButton>
    </div>
  </div>
</div>

<style>
  .grammar-content h3 {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
  }

  .grammar-content p {
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .section-image img {
    max-width: 100%;
    height: auto;
    border-radius: var(--card-radius);
  }

  .grammar-note {
    background: var(--color-bg);
    border-radius: var(--card-radius);
    padding: var(--space-5);
    margin: var(--space-4) 0;
  }

  .cta-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-4);
  }

  .cta-stack :global(.cta-btn) {
    text-decoration: none;
    width: fit-content;
  }
</style>