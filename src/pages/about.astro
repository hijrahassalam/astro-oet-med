---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <div class="about-page">
    <div class="page-hero">
      <div class="hero-bg">
        <div class="hero-grid"></div>
        <div class="hero-glow"></div>
      </div>
      <div class="container hero-inner">
        <div class="hero-badge">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M7 1L8.5 4.5L12.5 5L9.75 7.5L10.5 11.5L7 9.5L3.5 11.5L4.25 7.5L1.5 5L5.5 4.5L7 1Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          About
        </div>
        <h1>About This Platform</h1>
        <p>A structured learning platform for healthcare professionals preparing for OET.</p>
      </div>
    </div>

    <div class="container">
      <section class="content-section">
        <div class="section-header">
          <h2 class="section-title">Platform Overview</h2>
          <p class="section-subtitle">Everything you need to know about this learning experience</p>
        </div>
        <div class="cards-grid">
          <div class="info-card">
            <div class="card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="4"/>
                <path d="M4 20c0-4 4-6 8-6s8 2 8 6"/>
              </svg>
            </div>
            <h3>Who It's For</h3>
            <p>Healthcare professionals including doctors, nurses, pharmacists, dentists, and allied health workers preparing for OET.</p>
          </div>

          <div class="info-card">
            <div class="card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 6v6l4 2"/>
              </svg>
            </div>
            <h3>Why It Exists</h3>
            <p>Traditional OET resources lack medical specificity. This platform bridges the gap with contextually relevant materials and AI practice.</p>
          </div>

          <div class="info-card">
            <div class="card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
              </svg>
            </div>
            <h3>Learning Approach</h3>
            <p>Flipped classroom model: learn concepts at home through modules, practice skills via AI chatbot sessions.</p>
          </div>

          <div class="info-card">
            <div class="card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            </div>
            <h3>What You'll Find</h3>
            <p>Structured modules, AI-assisted practice, real medical contexts, and immediate feedback on your performance.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <div class="section-header">
          <h2 class="section-title">About the Lecturer</h2>
          <p class="section-subtitle">Meet your instructor</p>
        </div>
        <div class="lecturer-card">
          <div class="lecturer-banner"></div>
          <div class="lecturer-content">
            <div class="avatar-wrapper">
              <div class="avatar">
                <svg width="64" height="64" viewBox="0 0 64 64" fill="none">
                  <circle cx="32" cy="32" r="32" fill="var(--color-primary)"/>
                  <circle cx="32" cy="26" r="12" fill="#93c5fd"/>
                  <path d="M12 56C12 44.954 20.954 36 32 36C43.046 36 52 44.954 52 56" fill="#93c5fd"/>
                </svg>
              </div>
              <div class="avatar-badge">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                  <polyline points="22 4 12 14.01 9 11.01"/>
                </svg>
              </div>
            </div>
            <div class="lecturer-info">
              <h3 class="lecturer-name">Emilius German</h3>
              <p class="lecturer-role">Academic & Lecturer — President University</p>
              <p class="lecturer-intro">
                An academic specializing in English Language Education with a focus on Educational Technology (EdTech). Actively engaged in teaching, research, and developing digital-based learning innovations.
              </p>
            </div>
          </div>
        </div>

        <div class="cards-grid two-col">
          <div class="info-card">
            <div class="card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 14l9-5-9-5-9 5 9 5z"/>
                <path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"/>
                <path d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"/>
              </svg>
            </div>
            <h3>Areas of Expertise</h3>
            <ul>
              <li>English Language Education</li>
              <li>Educational Technology (EdTech)</li>
              <li>Applied Linguistics</li>
              <li>Curriculum Development</li>
            </ul>
          </div>

          <div class="info-card">
            <div class="card-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/>
                <path d="M21 21l-4.35-4.35"/>
              </svg>
            </div>
            <h3>Research Interests</h3>
            <ul>
              <li>Online learning</li>
              <li>Self-regulated learning</li>
              <li>Technology integration</li>
              <li>Teaching methods & media</li>
            </ul>
          </div>
        </div>

        <div class="info-card full-width">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            </svg>
          </div>
          <h3>Academic Profile</h3>
          <p>
            Maintains an applied research orientation, focusing on practical solutions in education.
            His research explores how technology can improve learning effectiveness within the Indonesian context.
            Currently pursuing a Doctoral (Ph.D.) degree in Educational Technology.
          </p>
        </div>
      </section>

      <footer class="page-footer">
        <div class="footer-content">
          <div class="footer-brand">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            <span>OET Learning Platform</span>
          </div>
          <p>Developed with care by <a href="https://hijrahassalam.com" target="_blank" rel="noopener">hijrahassalam.com</a></p>
        </div>
      </footer>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    min-height: 100vh;
    background: var(--color-bg);
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  /* Hero */
  .page-hero {
    position: relative;
    padding: var(--space-16) 0 var(--space-12);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--color-primary-50) 0%, var(--color-bg) 100%);
    z-index: 0;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, var(--color-primary-100) 1px, transparent 0);
    background-size: 32px 32px;
    opacity: 0.45;
    mask-image: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, transparent 60%);
    -webkit-mask-image: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, transparent 60%);
  }

  .hero-glow {
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(37, 99, 235, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 6px var(--space-4) 6px var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    box-shadow: var(--card-shadow);
  }

  .hero-badge svg {
    color: var(--color-primary);
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .page-hero p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 480px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* Content Section */
  .content-section {
    padding: var(--space-12) 0;
  }

  .section-header {
    margin-bottom: var(--space-8);
  }

  .section-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2);
  }

  .section-subtitle {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Cards Grid */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .cards-grid.two-col {
    grid-template-columns: repeat(2, 1fr);
  }

  .info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--card-radius);
    padding: var(--space-6);
    box-shadow: var(--card-shadow);
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .info-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .info-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
    border-color: var(--color-primary-200);
  }

  .info-card:hover::before {
    opacity: 1;
  }

  .info-card.full-width {
    grid-column: 1 / -1;
  }

  .card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, var(--color-primary-50), var(--color-primary-100));
    border-radius: 12px;
    margin-bottom: var(--space-4);
    color: var(--color-primary);
  }

  .info-card h3 {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-2);
    letter-spacing: -0.01em;
  }

  .info-card p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .info-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .info-card li {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    padding-left: var(--space-4);
    position: relative;
  }

  .info-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 6px;
    height: 6px;
    background: var(--color-primary);
    border-radius: 50%;
  }

  /* Lecturer Card */
  .lecturer-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--card-radius);
    overflow: hidden;
    margin-bottom: var(--space-6);
    box-shadow: var(--card-shadow);
    position: relative;
  }

  .lecturer-banner {
    height: 80px;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%);
    position: relative;
  }

  .lecturer-banner::after {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.08'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }

  .lecturer-content {
    display: flex;
    gap: var(--space-6);
    padding: 0 var(--space-6) var(--space-6);
    margin-top: -48px;
    position: relative;
  }

  .avatar-wrapper {
    position: relative;
    flex-shrink: 0;
  }

  .avatar {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    border: 4px solid var(--color-surface);
    box-shadow: var(--card-shadow);
    overflow: hidden;
  }

  .avatar-badge {
    position: absolute;
    bottom: 4px;
    right: 4px;
    width: 28px;
    height: 28px;
    background: var(--color-success);
    border-radius: 50%;
    border: 3px solid var(--color-surface);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
  }

  .lecturer-info {
    padding-top: 56px;
  }

  .lecturer-name {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-1);
  }

  .lecturer-role {
    font-size: var(--text-sm);
    color: var(--color-primary);
    font-weight: 500;
    margin-bottom: var(--space-4);
  }

  .lecturer-intro {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  /* Footer */
  .page-footer {
    padding: var(--space-12) 0;
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-8);
  }

  .footer-content {
    text-align: center;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .footer-brand svg {
    color: var(--color-primary);
  }

  .page-footer p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .page-footer a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .page-footer a:hover {
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .cards-grid,
    .cards-grid.two-col {
      grid-template-columns: 1fr;
    }

    .lecturer-content {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding-top: var(--space-4);
    }

    .lecturer-info {
      padding-top: 0;
    }

    .avatar-wrapper {
      margin-top: -48px;
    }
  }
</style>