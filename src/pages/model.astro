---
import BaseLayout from '../layouts/BaseLayout.astro';

const phases = [
  {
    number: 1,
    title: 'Understanding Basic Knowledge',
    subtitle: 'Asynchronous — Before Class',
    bloom: 'Understand',
    color: 'phase-blue',
    icon: 'book',
    activities: [
      'Study OET speaking structure and assessment criteria',
      'Learn key medical vocabulary and grammar content',
      'Complete quizzes with immediate AI platform feedback',
      'Build foundational linguistic and clinical knowledge independently',
    ],
  },
  {
    number: 2,
    title: 'Chatbot-Assisted Practice',
    subtitle: 'Asynchronous — Before Class',
    bloom: 'Apply & Analyze',
    color: 'phase-green',
    icon: 'chatbot',
    activities: [
      'Read chatbot usage guidelines and analyze role-play cue cards',
      'Use chatbot as a structured practice tool — step-by-step scaffolding',
      'Use chatbot as a conversational partner — simulated clinical interactions',
      'Apply and analyze linguistic/clinical knowledge with AI feedback',
    ],
  },
  {
    number: 3,
    title: 'Collaborative Practice & Reflection',
    subtitle: 'Face-to-Face — In Class',
    bloom: 'Evaluate, Create & Reflect',
    color: 'phase-purple',
    icon: 'users',
    activities: [
      'Perform collaborative role-plays with classmates',
      'Receive rubric-based feedback from the lecturer',
      'Create role-play videos for self-assessment',
      'Reflect on learning experience and build improvement strategies',
    ],
  },
];

---

<BaseLayout title="Learning Model">
  <div class="model-page">
    <div class="page-hero">
      <div class="hero-bg">
        <div class="hero-grid"></div>
        <div class="hero-glow"></div>
      </div>
      <div class="container hero-inner">
        <div class="hero-badge">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path d="M7 1L8.5 4.5L12.5 5L9.75 7.5L10.5 11.5L7 9.5L3.5 11.5L4.25 7.5L1.5 5L5.5 4.5L7 1Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Learning Model
        </div>
        <h1>Chatbot-Augmented Flipped Learning</h1>
        <p>A technology-enhanced framework for developing linguistic and clinical communication competence in healthcare professionals.</p>
      </div>
    </div>

    <div class="container">
      <!-- Section 1: Framework Overview -->
      <section class="content-section">
        <div class="section-header">
          <h2 class="section-title">Framework Overview</h2>
          <p class="section-subtitle">A Chatbot-Augmented Flipped Learning Framework</p>
        </div>
        <div class="info-card full-width">
          <p class="description-text">
            A Chatbot-Augmented Flipped Learning Framework is a technology-enhanced instructional framework that integrates flipped learning, AI chatbot scaffolding, collaborative role-play, lecturer feedback, and reflective learning to support the development of linguistic and clinical communication competence. The framework provides a systematic, interactive, and student-centered learning environment in which students actively engage in authentic healthcare communication tasks while continuously improving their speaking performance. This framework is particularly suitable for OET-oriented instruction and EMI healthcare education contexts because it promotes flexibility, personalization, interaction, and deep learning within a structured instructional process.
          </p>
        </div>
      </section>

      <!-- Section 2: Full Diagram -->
      <section class="content-section">
        <div class="section-header">
          <h2 class="section-title">Framework Diagram</h2>
          <p class="section-subtitle">Complete visual representation of the learning model</p>
        </div>
        <div class="diagram-wrapper">
          <img
            src="/images/model/framework.jpg"
            alt="A Chatbot-Augmented Flipped Learning Framework for Enhancing Linguistic and Clinical Communication Competence"
            class="diagram-image"
            loading="lazy"
          />
        </div>
      </section>

      <!-- Section 3: The Three Phases -->
      <section class="content-section">
        <div class="section-header">
          <h2 class="section-title">The Three Phases</h2>
          <p class="section-subtitle">From foundational understanding to deep learning</p>
        </div>
        <div class="phases-grid">
          {phases.map((phase) => (
            <div class={`phase-card ${phase.color}`}>
              <div class="phase-card-header">
                <div class="phase-number">{phase.number}</div>
                <div class="phase-meta">
                  <h3 class="phase-title">{phase.title}</h3>
                  <span class="phase-subtitle">{phase.subtitle}</span>
                </div>
              </div>
              <div class="phase-bloom-badge">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                  <path d="M2 17l10 5 10-5"/>
                  <path d="M2 12l10 5 10-5"/>
                </svg>
                <span>Bloom's: {phase.bloom}</span>
              </div>
              <ul class="phase-activities">
                {phase.activities.map((activity) => (
                  <li>{activity}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- Section 4: Bloom's Taxonomy Alignment -->
      <section class="content-section">
        <div class="section-header">
          <h2 class="section-title">Bloom's Taxonomy Alignment</h2>
          <p class="section-subtitle">Progressive cognitive engagement toward deep learning</p>
        </div>

        <div class="pyramid">
          <!-- Peak -->
          <div class="pyramid-tier pyramid-tier--goal">
            <div class="pyramid-bar">
              <div class="pyramid-content">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="pyramid-icon">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                <span class="pyramid-level">Deep Learning</span>
              </div>
              <span class="pyramid-phase-tag pyramid-phase-tag--goal">Goal</span>
            </div>
          </div>

          <!-- Phase 3 -->
          <div class="pyramid-tier pyramid-tier--phase3">
            <div class="pyramid-bar">
              <div class="pyramid-content">
                <span class="pyramid-level">Evaluate · Create · Reflect</span>
              </div>
              <span class="pyramid-phase-tag pyramid-phase-tag--phase3">Phase 3 — In Class</span>
            </div>
          </div>

          <!-- Phase 2 -->
          <div class="pyramid-tier pyramid-tier--phase2">
            <div class="pyramid-bar">
              <div class="pyramid-content">
                <span class="pyramid-level">Apply · Analyze</span>
              </div>
              <span class="pyramid-phase-tag pyramid-phase-tag--phase2">Phase 2 — Chatbot</span>
            </div>
          </div>

          <!-- Base -->
          <div class="pyramid-tier pyramid-tier--phase1">
            <div class="pyramid-bar">
              <div class="pyramid-content">
                <span class="pyramid-level">Understand</span>
              </div>
              <span class="pyramid-phase-tag pyramid-phase-tag--phase1">Phase 1 — Async</span>
            </div>
          </div>
        </div>

        <div class="bloom-legend">
          <div class="legend-item">
            <span class="legend-dot legend-dot--phase1" />
            <span>Phase 1 — Understand</span>
          </div>
          <div class="legend-item">
            <span class="legend-dot legend-dot--phase2" />
            <span>Phase 2 — Apply & Analyze</span>
          </div>
          <div class="legend-item">
            <span class="legend-dot legend-dot--phase3" />
            <span>Phase 3 — Evaluate, Create & Reflect</span>
          </div>
          <div class="legend-item">
            <span class="legend-dot legend-dot--goal" />
            <span>Goal — Deep Learning</span>
          </div>
        </div>
      </section>

      <footer class="page-footer">
        <div class="footer-content">
          <div class="footer-brand">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
            <span>OET Learning Platform</span>
          </div>
          <p>Developed with care by <a href="https://hijrahassalam.com" target="_blank" rel="noopener">hijrahassalam.com</a></p>
        </div>
      </footer>
    </div>
  </div>
</BaseLayout>

<style>
  .model-page {
    min-height: 100vh;
    background: var(--color-bg);
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 var(--space-6);
  }

  /* Hero */
  .page-hero {
    position: relative;
    padding: var(--space-16) 0 var(--space-12);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--color-primary-50) 0%, var(--color-bg) 100%);
    z-index: 0;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, var(--color-primary-100) 1px, transparent 0);
    background-size: 32px 32px;
    opacity: 0.45;
    mask-image: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, transparent 60%);
    -webkit-mask-image: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, transparent 60%);
  }

  .hero-glow {
    position: absolute;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(37, 99, 235, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 6px var(--space-4) 6px var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    box-shadow: var(--card-shadow);
  }

  .hero-badge svg {
    color: var(--color-primary);
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .page-hero p {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 560px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* Content Section */
  .content-section {
    padding: var(--space-12) 0;
  }

  .section-header {
    margin-bottom: var(--space-8);
  }

  .section-title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-2);
  }

  .section-subtitle {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Info Card */
  .info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--card-radius);
    padding: var(--space-6);
    box-shadow: var(--card-shadow);
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .info-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .info-card:hover::before {
    opacity: 1;
  }

  .info-card.full-width {
    margin-bottom: var(--space-4);
  }

  .info-card p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .description-text {
    font-size: var(--text-sm) !important;
    line-height: 1.8 !important;
  }

  /* Diagram */
  .diagram-wrapper {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--card-radius);
    padding: var(--space-4);
    box-shadow: var(--card-shadow);
    text-align: center;
    overflow: hidden;
  }

  .diagram-image {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  /* Phases Grid */
  .phases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .phase-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--card-radius);
    padding: var(--space-5);
    box-shadow: var(--card-shadow);
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .phase-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .phase-card:hover {
    box-shadow: var(--card-shadow-hover);
    transform: translateY(-2px);
  }

  .phase-card:hover::before {
    opacity: 1;
  }

  .phase-blue::before { background: linear-gradient(90deg, #2563eb, #60a5fa); }
  .phase-green::before { background: linear-gradient(90deg, #16a34a, #4ade80); }
  .phase-purple::before { background: linear-gradient(90deg, #9333ea, #c084fc); }

  .phase-blue { border-top: 3px solid #2563eb; }
  .phase-green { border-top: 3px solid #16a34a; }
  .phase-purple { border-top: 3px solid #9333ea; }

  .phase-card-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .phase-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    font-size: var(--text-lg);
    font-weight: 800;
    flex-shrink: 0;
  }

  .phase-blue .phase-number {
    background: #eff6ff;
    color: #2563eb;
  }

  .phase-green .phase-number {
    background: #f0fdf4;
    color: #16a34a;
  }

  .phase-purple .phase-number {
    background: #faf5ff;
    color: #9333ea;
  }

  .phase-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .phase-title {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .phase-subtitle {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .phase-bloom-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 4px 10px;
    background: var(--color-primary-50);
    color: var(--color-primary);
    border-radius: 6px;
    font-size: 11px;
    font-weight: 600;
    margin-bottom: var(--space-4);
  }

  .phase-bloom-badge svg {
    flex-shrink: 0;
  }

  .phase-activities {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .phase-activities li {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    padding-left: var(--space-4);
    position: relative;
    line-height: 1.5;
  }

  .phase-activities li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 6px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
  }

  .phase-blue .phase-activities li::before { background: #2563eb; }
  .phase-green .phase-activities li::before { background: #16a34a; }
  .phase-purple .phase-activities li::before { background: #9333ea; }

  /* Bloom's Pyramid */
  .pyramid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin-bottom: var(--space-10);
    padding: var(--space-6) 0;
  }

  .pyramid-tier {
    display: flex;
    justify-content: center;
  }

  .pyramid-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    border-radius: 12px;
    border: 1px solid;
    transition: all var(--transition-base);
    position: relative;
  }

  .pyramid-bar:hover {
    transform: translateY(-2px);
    box-shadow: var(--card-shadow-hover);
  }

  .pyramid-content {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .pyramid-icon {
    flex-shrink: 0;
  }

  .pyramid-level {
    font-size: var(--text-sm);
    font-weight: 700;
    white-space: nowrap;
  }

  .pyramid-phase-tag {
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 6px;
    white-space: nowrap;
  }

  /* Tier widths — gets narrower toward the top */
  .pyramid-tier--phase1 .pyramid-bar { width: 100%; max-width: 700px; }
  .pyramid-tier--phase2 .pyramid-bar { width: 100%; max-width: 560px; }
  .pyramid-tier--phase3 .pyramid-bar { width: 100%; max-width: 440px; }
  .pyramid-tier--goal   .pyramid-bar { width: 100%; max-width: 300px; }

  /* Phase 1 — Blue */
  .pyramid-tier--phase1 .pyramid-bar {
    background: linear-gradient(135deg, #eff6ff, #dbeafe);
    border-color: #93c5fd;
    color: #1e40af;
  }
  .pyramid-tier--phase1 .pyramid-level { color: #1e40af; }
  .pyramid-phase-tag--phase1 {
    background: #2563eb;
    color: white;
  }

  /* Phase 2 — Green */
  .pyramid-tier--phase2 .pyramid-bar {
    background: linear-gradient(135deg, #f0fdf4, #dcfce7);
    border-color: #86efac;
    color: #166534;
  }
  .pyramid-tier--phase2 .pyramid-level { color: #166534; }
  .pyramid-phase-tag--phase2 {
    background: #16a34a;
    color: white;
  }

  /* Phase 3 — Purple */
  .pyramid-tier--phase3 .pyramid-bar {
    background: linear-gradient(135deg, #faf5ff, #f3e8ff);
    border-color: #d8b4fe;
    color: #6b21a8;
  }
  .pyramid-tier--phase3 .pyramid-level { color: #6b21a8; }
  .pyramid-phase-tag--phase3 {
    background: #9333ea;
    color: white;
  }

  /* Goal — Gold */
  .pyramid-tier--goal .pyramid-bar {
    background: linear-gradient(135deg, #fffbeb, #fef3c7);
    border-color: #fcd34d;
    color: #92400e;
    box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.1);
  }
  .pyramid-tier--goal .pyramid-level { color: #92400e; }
  .pyramid-tier--goal .pyramid-icon { color: #f59e0b; }
  .pyramid-phase-tag--goal {
    background: #f59e0b;
    color: white;
  }

  /* Bloom Legend */
  .bloom-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .legend-dot--phase1 { background: #2563eb; }
  .legend-dot--phase2 { background: #16a34a; }
  .legend-dot--phase3 { background: #9333ea; }
  .legend-dot--goal { background: linear-gradient(135deg, #f59e0b, #f97316); }

  /* Footer */
  .page-footer {
    padding: var(--space-12) 0;
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-8);
  }

  .footer-content {
    text-align: center;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .footer-brand svg {
    color: var(--color-primary);
  }

  .footer-content p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0;
  }

  .footer-content a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 500;
  }

  .footer-content a:hover {
    text-decoration: underline;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .phases-grid {
      grid-template-columns: 1fr;
    }

    .bloom-content {
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .bloom-level {
      min-width: auto;
    }
  }
</style>
