---
import BaseLayout from '../layouts/BaseLayout.astro';
import ModuleCard from '../components/ModuleCard.astro';
import Footer from '../components/Footer.astro';

const modules = [
  {
    number: 1,
    title: 'Speaking 1',
    description: 'Doing role-play on pregnancy case — master foundational speaking skills with AI chatbot practice and patient-centered communication strategies.',
    slug: 'module-1',
    image: '/images/modules/speaking-1.jpg',
  },
  {
    number: 2,
    title: 'Speaking 2',
    description: 'Doing role-play on heart problem — build on foundational skills with advanced scenarios and specialized healthcare communication.',
    slug: 'module-2',
    image: '/images/modules/speaking-2.jpg',
  },
  {
    number: 3,
    title: 'Speaking 3',
    description: 'Doing role-play on blood sugar problem (diabetes) — develop professional fluency in complex clinical dialogues.',
    slug: 'module-3',
    image: '/images/modules/speaking-3.jpg',
  },
  {
    number: 4,
    title: 'Speaking 4',
    description: 'Doing role-play on vaccination — respond empathetically to patient concerns and explain medical risks and benefits.',
    slug: 'module-4',
    image: '/images/modules/speaking-4.jpg',
  },
  {
    number: 5,
    title: 'Speaking 5',
    description: 'Doing role-play on epigastric pain — analyze patient anxiety, explain diagnostic findings, and produce coherent OET-style role-plays.',
    slug: 'module-5',
    image: '/images/modules/speaking-5.jpg',
  },
];
---

<BaseLayout title="OET Learning Platform">
  <!-- Welcome Section -->
  <section class="hero">
    <div class="hero-bg">
      <div class="hero-grid"></div>
      <div class="hero-glow"></div>
    </div>
    <div class="container hero-inner">
      <div class="hero-badge">
        <svg class="hero-badge-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M7 1L8.5 4.5L12.5 5L9.75 7.5L10.5 11.5L7 9.5L3.5 11.5L4.25 7.5L1.5 5L5.5 4.5L7 1Z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        OET Speaking Preparation
      </div>

      <h1 class="hero-title">
        Welcome!
      </h1>

      <p class="hero-subtitle">
        Welcome to the OET Speaking Preparation course, designed to support active, independent, and meaningful learning in Medical English communication. Through the Chatbot-Augmented Flipped Learning framework, this platform provides structured learning materials integrated with AI chatbot support, flipped learning activities, collaborative role-plays, and reflective learning experiences.
      </p>

      <p class="hero-subtitle-secondary">
        Students are expected to develop linguistic competence and clinical communication skills through flexible, interactive, and authentic healthcare communication practices. Happy learning, practicing, and growing throughout your learning journey!
      </p>

      <div class="hero-actions">
        <a href="/modules/module-1" class="btn btn-primary btn-lg">
          Start Learning
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M6 4L10 8L6 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/syllabus" class="btn btn-outline btn-lg">
          View Syllabus
        </a>
      </div>
    </div>
  </section>

  <!-- Framework Section -->
  <section class="framework-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-heading">A Chatbot-Augmented Flipped Learning Framework</h2>
      </div>
      <div class="framework-card">
        <p class="framework-text">
          A Chatbot-Augmented Flipped Learning Framework is a technology-enhanced instructional framework that integrates flipped learning, AI chatbot scaffolding, collaborative role-play, lecturer feedback, and reflective learning to support the development of linguistic and clinical communication competence. The framework provides a systematic, interactive, and student-centered learning environment in which students actively engage in authentic healthcare communication tasks while continuously improving their speaking performance.
        </p>
        <p class="framework-text">
          This framework is particularly suitable for OET-oriented instruction and EMI healthcare education contexts because it promotes flexibility, personalization, interaction, and deep learning within a structured instructional process.
        </p>
      </div>
    </div>
  </section>

  <!-- Topics Section -->
  <section class="topics-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-heading">Topics</h2>
        <p class="section-subheading">
          Five speaking modules covering essential healthcare communication scenarios.
        </p>
      </div>
      <div class="topics-image-wrapper">
        <img src="/images/topics.jpg" alt="The Three Phases — From foundational understanding to deep learning" class="topics-image" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Modules Grid -->
  <section class="modules-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-heading">Learning Modules</h2>
        <p class="section-subheading">
          Work through each module sequentially to build your skills step by step.
        </p>
      </div>

      <div class="modules-grid">
        {modules.map((mod) => (
          <ModuleCard
            number={mod.number}
            title={mod.title}
            description={mod.description}
            slug={mod.slug}
            image={mod.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- User Guide Section -->
  <section class="guide-section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-heading">User Guide</h2>
        <p class="section-subheading">
          Your 3-Phase Path to Confident Medical English Communication
        </p>
      </div>
      <div class="guide-image-wrapper">
        <img src="/images/user-guide.jpg" alt="User Guide — Your 3-Phase Path to Confident Medical English Communication" class="guide-image" loading="lazy" />
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  /* Hero / Welcome */
  .hero {
    position: relative;
    padding: var(--space-16) 0 var(--space-12);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      var(--color-primary-50) 0%,
      var(--color-bg) 100%
    );
    z-index: 0;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 1px 1px, var(--color-primary-100) 1px, transparent 0);
    background-size: 32px 32px;
    opacity: 0.45;
    mask-image: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, transparent 60%);
    -webkit-mask-image: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, transparent 60%);
  }

  .hero-glow {
    position: absolute;
    top: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 800px;
    height: 500px;
    background: radial-gradient(ellipse, rgba(37, 99, 235, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 6px var(--space-4) 6px var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-6);
    box-shadow: var(--card-shadow);
  }

  .hero-badge-icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5.5vw, 3.75rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    line-height: 1.1;
    margin-bottom: var(--space-6);
    max-width: 700px;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 0 0 var(--space-4);
    line-height: var(--leading-relaxed);
  }

  .hero-subtitle-secondary {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 0 var(--space-8);
    line-height: var(--leading-relaxed);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  /* Section Headers */
  .section-header {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .section-heading {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-3);
  }

  .section-subheading {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    max-width: 520px;
    margin: 0 auto;
  }

  /* Framework Section */
  .framework-section {
    padding: var(--space-12) 0;
  }

  .framework-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--card-radius);
    padding: var(--space-8);
    box-shadow: var(--card-shadow);
    border-left: 3px solid var(--color-primary);
    max-width: 800px;
    margin: 0 auto;
  }

  .framework-text {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin: 0 0 var(--space-4);
  }

  .framework-text:last-child {
    margin-bottom: 0;
  }

  /* Topics Section */
  .topics-section {
    padding: var(--space-12) 0;
    background: var(--color-primary-50);
  }

  .topics-image-wrapper {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--card-radius);
    padding: var(--space-4);
    box-shadow: var(--card-shadow);
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .topics-image {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  /* Modules Section */
  .modules-section {
    padding: var(--space-16) 0;
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  /* User Guide Section */
  .guide-section {
    padding: var(--space-12) 0 var(--space-16);
  }

  .guide-image-wrapper {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--card-radius);
    padding: var(--space-4);
    box-shadow: var(--card-shadow);
    text-align: center;
    max-width: 900px;
    margin: 0 auto;
  }

  .guide-image {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: var(--space-12) 0 var(--space-8);
    }

    .hero-actions {
      flex-direction: column;
      width: 100%;
    }

    .hero-actions .btn {
      width: 100%;
      justify-content: center;
    }

    .modules-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
